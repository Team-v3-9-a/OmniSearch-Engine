# ============================================================
# OmniSearch Engine — PROD Environment Variables
# ============================================================
# Миша копирует на сервере:  cp .env.prod.example .env.prod
# Заполняет БОЕВЫЕ значения и запускает:
#   docker compose -f docker-compose.prod.yml up -d --build
# ============================================================

# ---- API Security & Routing ----
INTERNAL_API_SECRET=your_prod_internal_secret_here
API_EXTERNAL_URL=http://<SERVER_IP>:3000

# ---- PostgreSQL ----
DB_USER=admin_prod
DB_PASSWORD=changeme_prod_STRONG_PASSWORD
DB_NAME=videosense_prod

# ---- MinIO (S3-совместимое хранилище) ----
S3_ACCESS_KEY=minioadmin_prod
S3_SECRET_KEY=changeme_prod_STRONG_PASSWORD
S3_BUCKET=videos

# ---- Общая директория для обмена медиафайлами между сервисами ----
SHARED_MEDIA_PATH=/app/shared_media
