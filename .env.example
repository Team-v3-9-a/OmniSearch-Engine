# ============================================================
# OmniSearch Engine — Environment Variables
# ============================================================
# Скопируйте этот файл:  cp .env.example .env
# Заполните значения и запускайте:  docker compose up --build
# ============================================================

# ---- API Security & Routing ----
INTERNAL_API_SECRET=your_internal_secret_token_here

# ---- PostgreSQL ----
DB_USER=admin
DB_PASSWORD=changeme
DB_NAME=videosense

# ---- MinIO (S3-совместимое хранилище) ----
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme
S3_BUCKET=videos

# ---- Общая директория для обмена медиафайлами между сервисами ----
SHARED_MEDIA_PATH=/app/shared_media
apiSecret = super_secret_internal_token_123