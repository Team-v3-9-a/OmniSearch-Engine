# ============================================================
# OmniSearch Engine — DEV Environment Variables
# ============================================================
# Миша копирует на сервере:  cp .env.dev.example .env.dev
# Заполняет реальные значения и запускает:
#   docker compose -f docker-compose.dev.yml up -d --build
# ============================================================

# ---- API Security & Routing ----
INTERNAL_API_SECRET=your_dev_internal_secret_here
API_EXTERNAL_URL=http://<SERVER_IP>:3001

# ---- PostgreSQL ----
DB_USER=admin_dev
DB_PASSWORD=changeme_dev
DB_NAME=videosense_dev

# ---- MinIO (S3-совместимое хранилище) ----
S3_ACCESS_KEY=minioadmin_dev
S3_SECRET_KEY=changeme_dev
S3_BUCKET=videos

# ---- Общая директория для обмена медиафайлами между сервисами ----
SHARED_MEDIA_PATH=/app/shared_media
